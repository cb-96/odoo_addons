<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_team_roster_list" model="ir.ui.view">
        <field name="name">federation.team.roster.list</field>
        <field name="model">federation.team.roster</field>
        <field name="arch" type="xml">
            <list>
                <field name="team_id"/>
                <field name="season_id"/>
                <field name="competition_id"/>
                <field name="name" optional="hide"/>
                <field name="rule_set_id"/>
                <field name="status"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="line_count"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_federation_team_roster_form" model="ir.ui.view">
        <field name="name">federation.team.roster.form</field>
        <field name="model">federation.team.roster</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_draft" string="Reset to Draft" type="object" class="oe_highlight" invisible="status != 'active'"/>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_close" string="Close" type="object" invisible="status != 'active'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_lines" type="object" class="oe_stat_button" icon="fa-users" invisible="not line_count">
                            <field name="line_count" string="Players" widget="statinfo"/>
                        </button>
                        <button name="action_view_match_sheets" type="object" class="oe_stat_button" icon="fa-list" invisible="not match_sheet_count">
                            <field name="match_sheet_count" string="Match Sheets" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                        <div class="text-muted">Generated automatically from the linked team and scope.</div>
                    </div>
                    <group>
                        <group>
                            <field name="team_id"/>
                            <field name="season_id"/>
                            <field name="competition_id"/>
                            <field name="season_registration_id"/>
                        </group>
                        <group>
                            <field name="rule_set_id"/>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="min_players_required"/>
                            <field name="max_players_allowed"/>
                            <field name="club_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="ready_for_activation" readonly="1"/>
                            <field name="readiness_feedback" readonly="1" invisible="not readiness_feedback"/>
                        </group>
                        <group>
                            <field name="match_day_locked" readonly="1"/>
                            <field name="match_day_lock_feedback" readonly="1" invisible="not match_day_lock_feedback"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Roster Lines" name="roster_lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="player_id"/>
                                    <field name="status"/>
                                    <field name="jersey_number"/>
                                    <field name="is_captain"/>
                                    <field name="is_vice_captain"/>
                                    <field name="license_id"/>
                                    <field name="eligible" readonly="1"/>
                                    <field name="eligibility_feedback" readonly="1" optional="hide"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="notes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Audit History" name="audit_history">
                            <field name="audit_event_ids" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="event_on"/>
                                    <field name="event_type"/>
                                    <field name="player_id" optional="hide"/>
                                    <field name="match_sheet_id" optional="hide"/>
                                    <field name="author_id"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_team_roster_search" model="ir.ui.view">
        <field name="name">federation.team.roster.search</field>
        <field name="model">federation.team.roster</field>
        <field name="arch" type="xml">
            <search string="Search Team Rosters">
                <field name="name"/>
                <field name="team_id"/>
                <field name="season_id"/>
                <separator/>
                <group>
                    <filter name="team" string="Team" context="{'group_by': 'team_id'}"/>
                    <filter name="season" string="Season" context="{'group_by': 'season_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_federation_team_roster" model="ir.actions.act_window">
        <field name="name">Team Rosters</field>
        <field name="res_model">federation.team.roster</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_team_roster_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a roster to register players for a team and season.
            </p>
        </field>
    </record>
</odoo>