<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_federation_notification_log_form" model="ir.ui.view">
        <field name="name">federation.notification.log.form</field>
        <field name="model">federation.notification.log</field>
        <field name="arch" type="xml">
            <form string="Notification Log">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_target"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-external-link"
                                invisible="not target_res_id">
                            <div class="o_stat_info">
                                <span class="o_stat_text"><field name="target_display_name"/></span>
                                <span class="o_stat_text">View Record</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="notification_type"/>
                            <field name="state"/>
                            <field name="failure_category" readonly="1"/>
                            <field name="sent_on"/>
                        </group>
                        <group string="Target">
                            <field name="target_model"/>
                            <field name="target_res_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Recipient">
                            <field name="recipient_partner_id"/>
                            <field name="recipient_email"/>
                        </group>
                        <group string="Template">
                            <field name="template_xmlid"/>
                        </group>
                    </group>
                    <group string="Operator Feedback" invisible="not operator_message">
                        <field name="operator_message" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Message" invisible="not message">
                        <field name="message" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_federation_notification_log_list" model="ir.ui.view">
        <field name="name">federation.notification.log.list</field>
        <field name="model">federation.notification.log</field>
        <field name="arch" type="xml">
            <list string="Notification Logs">
                <field name="create_date"/>
                <field name="name"/>
                <field name="notification_type"/>
                <field name="target_model"/>
                <field name="recipient_email"/>
                <field name="state"/>
                <field name="failure_category" optional="show"/>
                <field name="sent_on"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_federation_notification_log_search" model="ir.ui.view">
        <field name="name">federation.notification.log.search</field>
        <field name="model">federation.notification.log</field>
        <field name="arch" type="xml">
            <search string="Search Notification Logs">
                <field name="name"/>
                <field name="target_model"/>
                <field name="recipient_email"/>
                <field name="failure_category"/>
                <filter name="email" string="Email" domain="[('notification_type', '=', 'email')]"/>
                <filter name="activity" string="Activity" domain="[('notification_type', '=', 'activity')]"/>
                <filter name="other" string="Other" domain="[('notification_type', '=', 'other')]"/>
                <filter name="pending" string="Pending" domain="[('state', '=', 'pending')]"/>
                <filter name="sent" string="Sent" domain="[('state', '=', 'sent')]"/>
                <filter name="failed" string="Failed" domain="[('state', '=', 'failed')]"/>
                <separator/>
                <group>
                    <filter name="group_failure_category" string="Failure Category" context="{'group_by': 'failure_category'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'notification_type'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="group_target_model" string="Target Model" context="{'group_by': 'target_model'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_notification_log" model="ir.actions.act_window">
        <field name="name">Notification Logs</field>
        <field name="res_model">federation.notification.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_notification_log_search"/>
    </record>

</odoo>