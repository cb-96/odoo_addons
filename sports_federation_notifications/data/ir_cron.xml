<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Scheduled Action: Notification Scan -->
    <record id="ir_cron_notification_scan" model="ir.cron">
        <field name="name">Federation: Notification Scan</field>
        <field name="model_id" ref="model_federation_notification_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_notification_scan()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_notification_log_retention" model="ir.cron">
        <field name="name">Federation: Purge Notification Logs</field>
        <field name="model_id" ref="model_federation_notification_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_purge_old_logs()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>