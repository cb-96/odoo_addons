<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_team_form" model="ir.ui.view">
        <field name="name">federation.team.form</field>
        <field name="model">federation.team</field>
        <field name="arch" type="xml">
            <form string="Team">
                <header>
                    <button name="action_archive" string="Archive" type="object"
                            class="btn-secondary" invisible="not active"/>
                    <button name="action_restore" string="Restore" type="object"
                            class="btn-secondary" invisible="active"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_registrations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o">
                            <field name="registration_count" widget="statinfo" string="Registrations"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <field name="logo" widget="image" class="oe_avatar" options="{'preview_image': 'logo'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Team Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Club">
                            <field name="club_id"/>
                        </group>
                        <group string="Classification">
                            <field name="category"/>
                            <field name="gender"/>
                        </group>
                    </group>
                    <group>
                        <group string="Contact">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_team_list" model="ir.ui.view">
        <field name="name">federation.team.list</field>
        <field name="model">federation.team</field>
        <field name="arch" type="xml">
            <list string="Teams">
                <field name="display_name" string="Team"/>
                <field name="code"/>
                <field name="club_id"/>
                <field name="category"/>
                <field name="gender"/>
                <field name="registration_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_team_search" model="ir.ui.view">
        <field name="name">federation.team.search</field>
        <field name="model">federation.team</field>
        <field name="arch" type="xml">
            <search string="Search Teams">
                <field name="name"/>
                <field name="code"/>
                <field name="club_id"/>
                <field name="category"/>
                <field name="gender"/>

                <separator/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter name="club" string="Club" context="{'group_by': 'club_id'}"/>
                    <filter name="cat" string="Category" context="{'group_by': 'category'}"/>
                    <filter name="gen" string="Gender" context="{'group_by': 'gender'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_team_action" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">federation.team</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_team_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first federation team.
            </p>
        </field>
    </record>

</odoo>