<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_federation_attachment_scan" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.federation.attachment.scan</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Sports Federation" name="sports_federation_base">
                    <block title="Upload Security" name="sports_federation_upload_security">
                        <setting id="federation_attachment_scan_command" string="Attachment Malware Scan" help="Configure the optional external command used to scan portal and partner uploads before acceptance.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="federation_attachment_scan_command" class="col-lg-4 o_light_label"/>
                                    <field name="federation_attachment_scan_command" class="col-lg-8" placeholder="/usr/local/bin/scan-upload"/>
                                </div>
                                <div class="row mt16">
                                    <label for="federation_attachment_scan_timeout_seconds" class="col-lg-4 o_light_label"/>
                                    <field name="federation_attachment_scan_timeout_seconds" class="col-lg-2"/>
                                </div>
                                <div class="text-muted mt8">
                                    The command receives upload bytes on stdin plus the metadata environment variables
                                    <code>SF_ATTACHMENT_POLICY</code>, <code>SF_ATTACHMENT_FILENAME</code>, and <code>SF_ATTACHMENT_MIMETYPE</code>.
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>