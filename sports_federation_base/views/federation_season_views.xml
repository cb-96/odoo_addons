<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_season_form" model="ir.ui.view">
        <field name="name">federation.season.form</field>
        <field name="model">federation.season</field>
        <field name="arch" type="xml">
            <form string="Season">
                <header>
                    <button name="action_open" string="Open" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary"
                            invisible="state != 'open'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <button name="action_archive" string="Archive" type="object"
                        class="btn-secondary" invisible="not active"/>
                    <button name="action_restore" string="Restore" type="object"
                        class="btn-secondary" invisible="active"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_registrations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o">
                            <field name="registration_count" widget="statinfo" string="Registrations"/>
                        </button>
                        <button name="action_view_confirmed_registrations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                invisible="not confirmed_registration_count">
                            <field name="confirmed_registration_count" widget="statinfo" string="Confirmed"/>
                        </button>
                        <button name="action_view_pending_registrations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-clock-o"
                                invisible="not pending_registration_count">
                            <field name="pending_registration_count" widget="statinfo" string="Pending"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Season Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group string="Planning Targets">
                            <field name="target_club_count"/>
                            <field name="target_team_count"/>
                            <field name="target_tournament_count"/>
                            <field name="target_participant_count"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_season_list" model="ir.ui.view">
        <field name="name">federation.season.list</field>
        <field name="model">federation.season</field>
        <field name="arch" type="xml">
            <list string="Seasons">
                <field name="name"/>
                <field name="code"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
                <field name="target_team_count" optional="hide"/>
                <field name="target_tournament_count" optional="hide"/>
                <field name="target_participant_count" optional="hide"/>
                <field name="registration_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_season_search" model="ir.ui.view">
        <field name="name">federation.season.search</field>
        <field name="model">federation.season</field>
        <field name="arch" type="xml">
            <search string="Search Seasons">
                <field name="name"/>
                <field name="code"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Open" domain="[('state', '=', 'open')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <group>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_season_action" model="ir.actions.act_window">
        <field name="name">Seasons</field>
        <field name="res_model">federation.season</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_season_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first federation season.
            </p>
        </field>
    </record>

</odoo>