<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_form_inherit_venue" model="ir.ui.view">
        <field name="name">federation.tournament.form.inherit.venue</field>
        <field name="model">federation.tournament</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='rule_set_id']" position="after">
                <field name="venue_id"/>
                <field name="venue_notes"/>
                <field name="required_playing_area_capability_ids" widget="many2many_tags" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_federation_tournament_stage_form_inherit_venue" model="ir.ui.view">
        <field name="name">federation.tournament.stage.form.inherit.venue</field>
        <field name="model">federation.tournament.stage</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_stage_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='notes']" position="after">
                <separator string="Rounds"/>
                <field name="round_ids"
                       context="{'default_stage_id': id}">
                    <list editable="bottom" default_order="sequence asc, id asc">
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="group_id" optional="hide" domain="[('stage_id', '=', id)]"/>
                        <field name="round_date"/>
                        <field name="venue_id"/>
                        <field name="match_count" readonly="1"/>
                        <field name="state"/>
                    </list>
                </field>
            </xpath>
        </field>
    </record>

</odoo>