<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_competition_form" model="ir.ui.view">
        <field name="name">federation.competition.form</field>
        <field name="model">federation.competition</field>
        <field name="arch" type="xml">
            <form string="Competition Template">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary"
                            invisible="state != 'active'"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_editions" type="object"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="edition_count" widget="statinfo" string="Editions"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Competition Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General">
                            <field name="competition_type"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Defaults">
                            <field name="rule_set_id"/>
                        </group>
                    </group>
                    <div class="alert alert-info d-flex justify-content-between align-items-start gap-3"
                         invisible="edition_count"
                         role="status">
                        <div>
                            <strong>Next step:</strong>
                            Define the default rules here first, then create a season-specific edition when you are ready to run this competition.
                        </div>
                        <button name="action_view_editions"
                                string="Open Editions"
                                type="object"
                                class="btn btn-link p-0 text-nowrap"/>
                    </div>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_competition_list" model="ir.ui.view">
        <field name="name">federation.competition.list</field>
        <field name="model">federation.competition</field>
        <field name="arch" type="xml">
            <list string="Competition Templates">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="competition_type"/>
                <field name="rule_set_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_federation_competition_search" model="ir.ui.view">
        <field name="name">federation.competition.search</field>
        <field name="model">federation.competition</field>
        <field name="arch" type="xml">
            <search string="Search Competition Templates">
                <field name="name"/>
                <field name="code"/>
                <field name="rule_set_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="active" string="Active" domain="[('state', '=', 'active')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <group>
                    <filter name="type" string="Type" context="{'group_by': 'competition_type'}"/>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="rule_set" string="Rule Set" context="{'group_by': 'rule_set_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_competition_action" model="ir.actions.act_window">
        <field name="name">Competition Templates</field>
        <field name="res_model">federation.competition</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_competition_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first competition template.
            </p>
            <p>
                Use templates for default rules, then create an edition for the season you are actually running.
            </p>
        </field>
    </record>

</odoo>