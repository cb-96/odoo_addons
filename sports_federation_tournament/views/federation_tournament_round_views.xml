<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_round_form" model="ir.ui.view">
        <field name="name">federation.tournament.round.form</field>
        <field name="model">federation.tournament.round</field>
        <field name="arch" type="xml">
            <form string="Tournament Round">
                <header>
                    <button name="action_schedule" string="Schedule" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete" type="object"
                            class="btn-primary" invisible="state != 'scheduled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="stage_id"/>
                            <field name="tournament_id"/>
                            <field name="group_id" domain="[('stage_id', '=', stage_id)]"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="round_date"/>
                            <field name="match_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Matches">
                            <field name="match_ids">
                                <list decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                                    <field name="scheduled_time" widget="float_time"/>
                                    <field name="home_team_id"/>
                                    <field name="away_team_id"/>
                                    <field name="home_score"/>
                                    <field name="away_score"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_federation_tournament_round_tree" model="ir.ui.view">
        <field name="name">federation.tournament.round.tree</field>
        <field name="model">federation.tournament.round</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="group_id"/>
                <field name="round_date" optional="hide"/>
                <field name="match_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_federation_tournament_round_search" model="ir.ui.view">
        <field name="name">federation.tournament.round.search</field>
        <field name="model">federation.tournament.round</field>
        <field name="arch" type="xml">
            <search string="Search Rounds">
                <field name="name"/>
                <field name="stage_id"/>
                <field name="tournament_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]"/>
                <filter name="completed" string="Completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <group>
                    <filter name="tournament" string="Tournament" context="{'group_by': 'tournament_id'}"/>
                    <filter name="stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_tournament_round_action" model="ir.actions.act_window">
        <field name="name">Tournament Rounds</field>
        <field name="res_model">federation.tournament.round</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_tournament_round_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Rounds are created by the schedule generation wizard.
            </p>
        </field>
    </record>

</odoo>
