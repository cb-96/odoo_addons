<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_group_form" model="ir.ui.view">
        <field name="name">federation.tournament.group.form</field>
        <field name="model">federation.tournament.group</field>
        <field name="arch" type="xml">
            <form string="Tournament Group">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_participants" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="participant_count" widget="statinfo" string="Participants"/>
                        </button>
                        <button name="action_view_matches" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="match_count" widget="statinfo" string="Matches"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Group Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="stage_id"/>
                            <field name="tournament_id"/>
                            <field name="sequence"/>
                            <field name="max_participants"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_tournament_group_list" model="ir.ui.view">
        <field name="name">federation.tournament.group.list</field>
        <field name="model">federation.tournament.group</field>
        <field name="arch" type="xml">
            <list string="Tournament Groups">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="stage_id"/>
                <field name="max_participants"/>
                <field name="participant_count"/>
                <field name="match_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_tournament_group_search" model="ir.ui.view">
        <field name="name">federation.tournament.group.search</field>
        <field name="model">federation.tournament.group</field>
        <field name="arch" type="xml">
            <search string="Search Groups">
                <field name="name"/>
                <field name="stage_id"/>
                <field name="tournament_id"/>
                <separator/>
                <group>
                    <filter name="stage" string="Stage" context="{'group_by': 'stage_id'}"/>
                    <filter name="tournament" string="Tournament" context="{'group_by': 'tournament_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_tournament_group_action" model="ir.actions.act_window">
        <field name="name">Tournament Groups</field>
        <field name="res_model">federation.tournament.group</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_tournament_group_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tournament group.
            </p>
        </field>
    </record>

</odoo>