<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_form" model="ir.ui.view">
        <field name="name">federation.tournament.form</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <form string="Tournament">
                <header>
                    <button name="action_open" string="Open" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start" string="Start" type="object" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_close" string="Close" type="object" class="btn-secondary"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('closed', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <button name="action_archive" string="Archive" type="object"
                        class="btn-secondary" invisible="not active"/>
                    <button name="action_restore" string="Restore" type="object"
                        class="btn-secondary" invisible="active"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,in_progress,closed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_stages" type="object"
                                class="oe_stat_button" icon="fa-sitemap">
                            <field name="stage_count" widget="statinfo" string="Stages"/>
                        </button>
                        <button name="action_view_participants" type="object"
                                class="oe_stat_button" icon="fa-users">
                            <field name="participant_count" widget="statinfo" string="Participants"/>
                        </button>
                        <button name="action_view_matches" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="match_count" widget="statinfo" string="Matches"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Tournament Name"/>
                        </h1>
                        <h3>
                            <field name="code" placeholder="Code"/>
                        </h3>
                    </div>
                    <div class="alert alert-info d-flex justify-content-between align-items-start gap-3"
                         invisible="participant_count"
                         role="status">
                        <div>
                            <strong>Next step:</strong>
                            Register and confirm the participating teams before scheduling matches or starting the tournament.
                        </div>
                        <button name="action_view_participants"
                                string="Open Participants"
                                type="object"
                                class="btn btn-link p-0 text-nowrap"/>
                    </div>
                    <div class="alert alert-warning d-flex justify-content-between align-items-start gap-3"
                         invisible="state not in ('draft', 'open') or not participant_count"
                         role="alert">
                        <div>
                            <strong>Check before start:</strong>
                            Use Participants to confirm teams and resolve any readiness issues before you move into active tournament operations.
                        </div>
                        <button name="action_view_participants"
                                string="Review Participants"
                                type="object"
                                class="btn btn-link p-0 text-nowrap"/>
                    </div>
                    <notebook>
                        <page string="Basic Info" name="basic_info">
                            <group>
                                <group>
                                    <field name="tournament_type"/>
                                    <field name="max_participants"/>
                                    <field name="edition_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Scope" name="scope">
                            <group>
                                <group>
                                    <field name="season_id"/>
                                    <field name="competition_id"/>
                                    <field name="category"/>
                                    <field name="gender"/>
                                </group>
                            </group>
                        </page>
                        <page string="Schedule &amp; Rounds" name="schedule">
                            <group>
                                <group>
                                    <field name="date_start"/>
                                    <field name="date_end" invisible="tournament_type == 'single_day'"/>
                                    <field name="location"/>
                                </group>
                            </group>
                        </page>
                        <page string="Rules &amp; Overrides" name="rules">
                            <group>
                                <group>
                                    <field name="rule_set_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_tournament_list" model="ir.ui.view">
        <field name="name">federation.tournament.list</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <list string="Tournaments">
                <field name="name"/>
                <field name="code" optional="hide"/>
                <field name="season_id"/>
                <field name="category" optional="show"/>
                <field name="gender" optional="show"/>
                <field name="competition_id" optional="show"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="tournament_type" optional="hide"/>
                <field name="state"/>
                <field name="participant_count"/>
                <field name="match_count" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_federation_tournament_search" model="ir.ui.view">
        <field name="name">federation.tournament.search</field>
        <field name="model">federation.tournament</field>
        <field name="arch" type="xml">
            <search string="Search Tournaments">
                <field name="name"/>
                <field name="code"/>
                <field name="season_id"/>
                <field name="competition_id"/>
                <field name="location"/>
                <filter name="active" string="Active" domain="[('state', 'in', ('open', 'in_progress'))]"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Open" domain="[('state', '=', 'open')]"/>
                <filter name="in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <separator/>
                <group>
                    <filter name="season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="competition" string="Competition" context="{'group_by': 'competition_id'}"/>
                    <filter name="category" string="Category" context="{'group_by': 'category'}"/>
                    <filter name="gender" string="Gender" context="{'group_by': 'gender'}"/>
                    <filter name="type" string="Type" context="{'group_by': 'tournament_type'}"/>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_tournament_action" model="ir.actions.act_window">
        <field name="name">Tournaments</field>
        <field name="res_model">federation.tournament</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_tournament_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tournament.
            </p>
            <p>
                After setup, use Participants to capture accepted registrations and confirm teams before planning matches.
            </p>
        </field>
    </record>

</odoo>