<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_tournament_workspaces" name="My Tournament Workspaces">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-4 align-items-end">
                    <div class="col-lg-8">
                        <h2><i class="fa fa-sitemap me-2"/>Active Tournament Workspace</h2>
                        <p class="text-muted mb-0">
                            Review registration status, roster checkpoints, match-day submission work,
                            and result-side follow-up for your visible teams.
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <a href="/my/tournament-registrations" class="btn btn-outline-primary btn-sm me-2">
                            <i class="fa fa-trophy me-1"/> Registration Queue
                        </a>
                        <a href="/my/match-day" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-clipboard me-1"/> Match Day
                        </a>
                    </div>
                </div>

                <div t-if="not has_workspace_access" class="alert alert-warning" role="alert">
                    <i class="fa fa-info-circle me-2"/>
                    You do not currently have a club or team-scoped portal assignment for tournament operations.
                </div>

                <div t-elif="not workspace_entries" class="alert alert-info" role="status">
                    <i class="fa fa-info-circle me-2"/>
                    No active tournaments currently require action for your visible teams.
                </div>

                <div class="row" t-else="">
                    <t t-foreach="workspace_entries" t-as="workspace">
                        <t t-set="tournament" t-value="workspace['tournament']"/>
                        <t t-set="team" t-value="workspace['team']"/>
                        <t t-set="registration_checkpoint" t-value="workspace['registration_checkpoint']"/>
                        <t t-set="roster_checkpoint" t-value="workspace['roster_checkpoint']"/>
                        <div class="col-12 col-xl-6 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-3 gap-2 flex-wrap">
                                        <div>
                                            <h4 class="card-title mb-1"><t t-esc="tournament.name"/></h4>
                                            <div class="text-muted">
                                                <strong><t t-esc="team.name"/></strong>
                                                <t t-if="workspace['club']"> · <t t-esc="workspace['club'].name"/></t>
                                            </div>
                                        </div>
                                        <span class="badge rounded-pill text-bg-dark">
                                            <t t-esc="dict(tournament._fields['state'].selection).get(tournament.state)"/>
                                        </span>
                                    </div>

                                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                            <strong>Registration</strong>
                                            <span t-attf-class="badge rounded-pill text-bg-#{registration_checkpoint['tone']}">
                                                <t t-esc="registration_checkpoint['label']"/>
                                            </span>
                                        </div>
                                        <p class="small text-muted mb-0 mt-2" style="white-space: pre-line;">
                                            <t t-esc="registration_checkpoint['detail']"/>
                                        </p>
                                    </div>

                                    <div class="border rounded p-3 mb-3 bg-light-subtle">
                                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                            <strong>Roster Checkpoint</strong>
                                            <span t-attf-class="badge rounded-pill text-bg-#{roster_checkpoint['tone']}">
                                                <t t-esc="roster_checkpoint['label']"/>
                                            </span>
                                        </div>
                                        <p class="small text-muted mb-0 mt-2" style="white-space: pre-line;">
                                            <t t-esc="roster_checkpoint['detail']"/>
                                        </p>
                                    </div>

                                    <div class="row g-3 mb-3">
                                        <div class="col-sm-6">
                                            <div class="border rounded p-3 h-100">
                                                <div class="text-muted small text-uppercase">Match-Day Sheets</div>
                                                <div class="display-6"><t t-esc="len(workspace['upcoming_match_sheets'])"/></div>
                                                <p class="small text-muted mb-0">
                                                    <t t-esc="workspace['pending_match_day_count']"/> still in draft.
                                                </p>
                                            </div>
                                        </div>
                                        <div class="col-sm-6">
                                            <div class="border rounded p-3 h-100">
                                                <div class="text-muted small text-uppercase">Result Follow-Up</div>
                                                <div class="display-6"><t t-esc="workspace['result_follow_up_count']"/></div>
                                                <p class="small text-muted mb-0">Done matches still waiting for result closure.</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-auto d-flex gap-2 flex-wrap">
                                        <a t-attf-href="/my/tournament-workspaces/#{tournament.id}/#{team.id}" class="btn btn-primary btn-sm">
                                            Open Workspace
                                        </a>
                                        <a href="/my/match-day" class="btn btn-outline-secondary btn-sm">
                                            Match Day
                                        </a>
                                        <a t-if="workspace['roster']" t-attf-href="/my/rosters/#{workspace['roster'].id}" class="btn btn-outline-secondary btn-sm">
                                            View Roster
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>

                <t t-if="pager and pager['page_count'] &gt; 1" t-call="portal.portal_pager"/>
            </div>
        </t>
    </template>

    <template id="portal_my_tournament_workspace_detail" name="Tournament Workspace Detail">
        <t t-call="portal.portal_layout">
            <t t-set="tournament" t-value="workspace['tournament']"/>
            <t t-set="team" t-value="workspace['team']"/>
            <t t-set="registration_checkpoint" t-value="workspace['registration_checkpoint']"/>
            <t t-set="roster_checkpoint" t-value="workspace['roster_checkpoint']"/>
            <div class="container py-4">
                <div class="row mb-4 align-items-end">
                    <div class="col-lg-8">
                        <a href="/my/tournament-workspaces" class="text-decoration-none small text-muted">
                            <i class="fa fa-chevron-left me-1"/> Back to workspace
                        </a>
                        <h2 class="mt-2 mb-1"><t t-esc="tournament.name"/></h2>
                        <p class="text-muted mb-0">
                            <strong><t t-esc="team.name"/></strong>
                            <t t-if="workspace['club']"> · <t t-esc="workspace['club'].name"/></t>
                        </p>
                    </div>
                    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                        <span class="badge rounded-pill text-bg-dark me-2">
                            <t t-esc="dict(tournament._fields['state'].selection).get(tournament.state)"/>
                        </span>
                        <t t-if="workspace['roster']">
                            <a t-attf-href="/my/rosters/#{workspace['roster'].id}" class="btn btn-outline-primary btn-sm">
                                <i class="fa fa-users me-1"/> Roster
                            </a>
                        </t>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-12 col-xl-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-2">
                                    <h5 class="card-title mb-0">Registration Status</h5>
                                    <span t-attf-class="badge rounded-pill text-bg-#{registration_checkpoint['tone']}">
                                        <t t-esc="registration_checkpoint['label']"/>
                                    </span>
                                </div>
                                <p class="small text-muted mb-3" style="white-space: pre-line;">
                                    <t t-esc="registration_checkpoint['detail']"/>
                                </p>
                                <dl class="row mb-0 small">
                                    <dt class="col-sm-4">Request</dt>
                                    <dd class="col-sm-8">
                                        <t t-if="workspace['tournament_registration']">
                                            <t t-esc="workspace['tournament_registration'].name"/>
                                            · <t t-esc="dict(workspace['tournament_registration']._fields['state'].selection).get(workspace['tournament_registration'].state)"/>
                                        </t>
                                        <t t-else="">No request linked</t>
                                    </dd>
                                    <dt class="col-sm-4">Participant</dt>
                                    <dd class="col-sm-8">
                                        <t t-if="workspace['participant']">
                                            <t t-esc="dict(workspace['participant']._fields['state'].selection).get(workspace['participant'].state)"/>
                                        </t>
                                        <t t-else="">Not yet created</t>
                                    </dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-xl-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-2">
                                    <h5 class="card-title mb-0">Roster Checkpoint</h5>
                                    <span t-attf-class="badge rounded-pill text-bg-#{roster_checkpoint['tone']}">
                                        <t t-esc="roster_checkpoint['label']"/>
                                    </span>
                                </div>
                                <p class="small text-muted mb-3" style="white-space: pre-line;">
                                    <t t-esc="roster_checkpoint['detail']"/>
                                </p>
                                <dl class="row mb-0 small" t-if="workspace['roster']">
                                    <dt class="col-sm-4">Roster</dt>
                                    <dd class="col-sm-8"><t t-esc="workspace['roster'].name"/></dd>
                                    <dt class="col-sm-4">Status</dt>
                                    <dd class="col-sm-8"><t t-esc="dict(workspace['roster']._fields['status'].selection).get(workspace['roster'].status)"/></dd>
                                    <dt class="col-sm-4">Competition Scope</dt>
                                    <dd class="col-sm-8"><t t-esc="workspace['roster'].competition_id.display_name if workspace['roster'].competition_id else 'Season-wide roster'"/></dd>
                                </dl>
                                <p class="small text-muted mb-0" t-if="not workspace['roster']">
                                    No roster is currently linked to this team for the tournament season.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                            <h4 class="card-title mb-0">Match-Day Submission Tracking</h4>
                            <a href="/my/match-day" class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-clipboard me-1"/> Open Match-Day Queue
                            </a>
                        </div>
                        <div t-if="workspace['upcoming_match_sheets']">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <caption class="visually-hidden">Upcoming match-day submission tasks for this tournament workspace.</caption>
                                    <thead>
                                        <tr>
                                            <th scope="col">Kickoff</th>
                                            <th scope="col">Opponent</th>
                                            <th scope="col">Sheet Status</th>
                                            <th scope="col">Submission Readiness</th>
                                            <th scope="col" class="text-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="workspace['upcoming_match_sheets']" t-as="sheet">
                                            <t t-set="match" t-value="sheet.match_id"/>
                                            <t t-set="opponent" t-value="match.away_team_id if match.home_team_id == team else match.home_team_id"/>
                                            <tr>
                                                <td><span t-field="sheet.match_kickoff"/></td>
                                                <td><t t-esc="opponent.display_name if opponent else 'TBD'"/></td>
                                                <td>
                                                    <span class="badge text-bg-light border">
                                                        <t t-esc="dict(sheet._fields['state'].selection).get(sheet.state)"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <span t-if="sheet.ready_for_submission" class="badge text-bg-success">Ready</span>
                                                    <span t-else="" class="badge text-bg-warning">Needs attention</span>
                                                </td>
                                                <td class="text-end">
                                                    <a t-attf-href="/my/match-sheets/#{sheet.id}" class="btn btn-outline-primary btn-sm">View Sheet</a>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div t-else="" class="text-muted">
                            No scheduled match-day sheets are currently pending for this team in the tournament.
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                            <h4 class="card-title mb-0">Result Follow-Up Visibility</h4>
                            <a href="/my/match-sheets" class="btn btn-outline-secondary btn-sm">
                                <i class="fa fa-history me-1"/> Match Sheets
                            </a>
                        </div>
                        <div t-if="workspace['result_follow_up_rows']">
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0">
                                    <caption class="visually-hidden">Finished matches in this tournament workspace that still need result follow-up.</caption>
                                    <thead>
                                        <tr>
                                            <th scope="col">Match</th>
                                            <th scope="col">Score</th>
                                            <th scope="col">Result State</th>
                                            <th scope="col">Latest Audit</th>
                                            <th scope="col" class="text-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="workspace['result_follow_up_rows']" t-as="row">
                                            <t t-set="match" t-value="row['match']"/>
                                            <t t-set="sheet" t-value="row['sheet']"/>
                                            <t t-set="opponent" t-value="match.away_team_id if match.home_team_id == team else match.home_team_id"/>
                                            <t t-set="latest_audit" t-value="match.result_audit_ids[:1]"/>
                                            <tr>
                                                <td>
                                                    <div><span t-field="match.date_scheduled"/></div>
                                                    <div class="text-muted"><t t-esc="opponent.display_name if opponent else 'TBD'"/></div>
                                                </td>
                                                <td>
                                                    <t t-if="match.home_score is not False and match.away_score is not False">
                                                        <t t-esc="match.home_score"/> - <t t-esc="match.away_score"/>
                                                    </t>
                                                    <t t-else="">Not recorded</t>
                                                </td>
                                                <td>
                                                    <span class="badge text-bg-light border">
                                                        <t t-esc="dict(match._fields['result_state'].selection).get(match.result_state)"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <t t-if="latest_audit">
                                                        <div><t t-esc="latest_audit.description"/></div>
                                                        <div t-if="latest_audit.reason" class="text-muted small"><t t-esc="latest_audit.reason"/></div>
                                                    </t>
                                                    <t t-else="" class="text-muted">No audit event recorded yet.</t>
                                                </td>
                                                <td class="text-end">
                                                    <a t-if="sheet" t-attf-href="/my/match-sheets/#{sheet.id}" class="btn btn-outline-primary btn-sm">View Sheet</a>
                                                    <span t-else="" class="text-muted small">No team sheet</span>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        <div t-else="" class="text-muted">
                            No finished matches currently require result-side follow-up for this team.
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>