<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Portal navigation: add federation links to sidebar            -->
    <!-- ============================================================ -->

    <template id="portal_my_home_federation" name="Federation Portal Home"
              inherit_id="portal.portal_my_home" priority="30">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <t t-call="sports_federation_portal.portal_federation_links"/>
        </xpath>
    </template>

    <template id="portal_federation_links" name="Federation Portal Links">

        <!-- ── Club representative portal ─────────────────────────── -->
        <div t-if="federation_representative" class="o_fed_portal_home mb-4">

            <!-- Club context banner -->
            <p class="text-muted small mb-2">
                <i class="fa fa-shield me-1"/>
                Managing <strong><t t-esc="federation_club.name if federation_club else 'your club'"/></strong>
            </p>

            <!-- Primary CTA: Tournament Workspace -->
            <a href="/my/tournament-workspaces"
               class="card mb-3 text-decoration-none border-primary o_fed_primary_cta">
                <div class="card-body py-3 d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="fw-semibold text-primary">
                            <i class="fa fa-sitemap me-2"/>Tournament Workspace
                        </div>
                        <div class="text-muted small mt-1">
                            All active registrations, roster checkpoints, match-day tasks, and
                            result follow-up in one place.
                        </div>
                    </div>
                    <i class="fa fa-chevron-right text-primary flex-shrink-0"/>
                </div>
            </a>

            <!-- Numbered workflow steps -->
            <div class="card mb-3">
                <div class="card-header py-2 bg-transparent">
                    <span class="small fw-semibold text-uppercase text-muted">Season workflow</span>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/my/season-registrations"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">
                        <span class="badge bg-light text-dark border rounded-circle d-inline-flex
                                     align-items-center justify-content-center flex-shrink-0"
                              style="width:24px;height:24px;font-size:.75rem;">1</span>
                        <div>
                            <div class="fw-semibold small">Season Registrations</div>
                            <div class="text-muted" style="font-size:.8rem;">
                                Register teams for the current season
                            </div>
                        </div>
                    </a>
                    <a href="/my/rosters"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">
                        <span class="badge bg-light text-dark border rounded-circle d-inline-flex
                                     align-items-center justify-content-center flex-shrink-0"
                              style="width:24px;height:24px;font-size:.75rem;">2</span>
                        <div>
                            <div class="fw-semibold small">Rosters</div>
                            <div class="text-muted" style="font-size:.8rem;">
                                Build and manage player rosters
                            </div>
                        </div>
                    </a>
                    <a href="/my/tournament-registrations"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">
                        <span class="badge bg-light text-dark border rounded-circle d-inline-flex
                                     align-items-center justify-content-center flex-shrink-0"
                              style="width:24px;height:24px;font-size:.75rem;">3</span>
                        <div>
                            <div class="fw-semibold small">Tournament Registrations</div>
                            <div class="text-muted" style="font-size:.8rem;">
                                Apply and track tournament entries
                            </div>
                        </div>
                    </a>
                    <a href="/my/match-day"
                       class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">
                        <span class="badge bg-light text-dark border rounded-circle d-inline-flex
                                     align-items-center justify-content-center flex-shrink-0"
                              style="width:24px;height:24px;font-size:.75rem;">4</span>
                        <div>
                            <div class="fw-semibold small">Match Day</div>
                            <div class="text-muted" style="font-size:.8rem;">
                                Submit squad sheets and track match results
                            </div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Secondary quick links -->
            <div class="d-flex flex-wrap gap-2">
                <a href="/my/teams" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-users me-1"/>Teams
                </a>
                <a href="/my/players" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-user me-1"/>Players
                </a>
                <a href="/my/match-sheets" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-list-alt me-1"/>Match Sheets
                </a>
                <a href="/my/club" class="btn btn-outline-secondary btn-sm">
                    <i class="fa fa-shield me-1"/>Club Info
                </a>
            </div>
        </div>

        <!-- ── Referee portal ──────────────────────────────────────── -->
        <div t-if="federation_referee" class="o_fed_portal_home mb-4">
            <a href="/my/referee-assignments"
               class="card text-decoration-none border-primary o_fed_primary_cta">
                <div class="card-body py-3 d-flex align-items-center justify-content-between gap-3">
                    <div>
                        <div class="fw-semibold text-primary">
                            <i class="fa fa-flag me-2"/>My Officiating Assignments
                        </div>
                        <div class="text-muted small mt-1">
                            Review assigned matches and respond before the confirmation deadline.
                        </div>
                    </div>
                    <i class="fa fa-chevron-right text-primary flex-shrink-0"/>
                </div>
            </a>
        </div>

        <!-- ── No assignment ───────────────────────────────────────── -->
        <div t-if="not federation_representative and not federation_referee">
            <div class="alert alert-info">
                <i class="fa fa-info-circle me-2"/>
                You are not currently assigned as a club representative or match official.
                Please contact the federation for access.
            </div>
        </div>

    </template>

    <!-- ============================================================ -->
    <!-- My Club Page                                                  -->
    <!-- ============================================================ -->

    <template id="portal_my_club" name="My Club">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-shield me-2"/>
                            <t t-esc="club.name if club else 'My Club'"/>
                        </h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/home" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-arrow-left me-1"/>Back
                        </a>
                    </div>
                </div>

                <div t-if="error" class="alert alert-warning">
                    <t t-esc="error"/>
                </div>

                <t t-if="club">
                    <div class="card mb-4">
                        <div class="card-body">
                            <table class="table table-sm mb-0">
                                <tr t-if="club.code">
                                    <th style="width:140px">Code</th>
                                    <td><t t-esc="club.code"/></td>
                                </tr>
                                <tr t-if="club.email">
                                    <th>Email</th>
                                    <td><a t-att-href="'mailto:' + club.email" t-esc="club.email"/></td>
                                </tr>
                                <tr t-if="club.phone">
                                    <th>Phone</th>
                                    <td><t t-esc="club.phone"/></td>
                                </tr>
                                <tr t-if="club.city or club.country_id">
                                    <th>Location</th>
                                    <td>
                                        <t t-esc="club.city"/>
                                        <t t-if="club.city and club.country_id">, </t>
                                        <t t-if="club.country_id" t-esc="club.country_id.name"/>
                                    </td>
                                </tr>
                                <tr t-if="club.website">
                                    <th>Website</th>
                                    <td><a t-att-href="club.website" t-esc="club.website"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <a href="/my/teams" class="btn btn-outline-primary btn-sm">
                            <i class="fa fa-users me-1"/>Teams
                            <t t-if="teams">(<t t-esc="len(teams)"/>)</t>
                        </a>
                        <a href="/my/season-registrations" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-calendar me-1"/>Season Registrations
                        </a>
                        <a href="/my/tournament-workspaces" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-sitemap me-1"/>Tournament Workspace
                        </a>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- My Teams Page                                                 -->
    <!-- ============================================================ -->

    <template id="portal_my_teams" name="My Teams">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-users me-2"/>Teams</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/teams/new" class="btn btn-primary">
                            <i class="fa fa-plus me-1"/>New Team
                        </a>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <div t-if="teams">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <caption class="visually-hidden">Teams available to the current club representative.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Team Name</th>
                                    <th scope="col">Category</th>
                                    <th scope="col">Gender</th>
                                    <th scope="col" class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="teams" t-as="team">
                                    <tr>
                                        <td class="fw-semibold"><t t-esc="team.name"/></td>
                                        <td><t t-esc="dict(team._fields['category'].selection).get(team.category) if team.category else '—'"/></td>
                                        <td><t t-esc="dict(team._fields['gender'].selection).get(team.gender) if team.gender else '—'"/></td>
                                        <td class="text-end">
                                            <a t-attf-href="/my/season-registration/new?team_id=#{team.id}"
                                               class="btn btn-sm btn-outline-primary">
                                                Register for Season
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted small mt-1">
                        After registering a team for a season, build a
                        <a href="/my/rosters">roster</a> to prepare for tournament entry.
                    </p>
                </div>

                <div t-else="" class="text-center py-5">
                    <i class="fa fa-users fa-3x text-muted mb-3 d-block"/>
                    <p class="fw-semibold mb-1">No teams yet</p>
                    <p class="text-muted mb-3">
                        Create your first team, then register it for the current season.
                    </p>
                    <a href="/my/teams/new" class="btn btn-primary">Create Your First Team</a>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- New Team Form                                               -->
    <!-- ============================================================ -->

    <template id="portal_my_team_new" name="New Team">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3">
                    <div class="col">
                        <h2><i class="fa fa-plus me-2"/>New Team</h2>
                    </div>
                </div>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <form action="/my/teams/new" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="mb-3">
                        <label class="form-label" for="team_name">Team Name</label>
                        <input id="team_name" class="form-control" name="name" required="required"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="team_club_id">Club</label>
                        <select id="team_club_id" name="club_id" class="form-select">
                            <t t-foreach="clubs" t-as="club">
                                <option t-att-value="club.id"><t t-esc="club.name"/></option>
                            </t>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="team_category">Category</label>
                        <select id="team_category" name="category" class="form-select" required="required">
                            <option value="senior">Senior</option>
                            <option value="youth">Youth</option>
                            <option value="junior">Junior</option>
                            <option value="cadet">Cadet</option>
                            <option value="mini">Mini</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="team_gender">Gender</label>
                        <select id="team_gender" name="gender" class="form-select" required="required">
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="mixed">Mixed</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="team_email">Email</label>
                        <input id="team_email" class="form-control" name="email" type="email"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="team_phone">Phone</label>
                        <input id="team_phone" class="form-control" name="phone"/>
                    </div>

                    <button class="btn btn-primary" type="submit">Create Team</button>
                    <a class="btn btn-secondary" href="/my/teams">Cancel</a>
                </form>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- My Players Page                                               -->
    <!-- ============================================================ -->

    <template id="portal_my_players" name="My Players">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-user me-2"/>Players</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/players/new" class="btn btn-primary">
                            <i class="fa fa-plus me-1"/>Add Player
                        </a>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <!-- Filters -->
                <form method="GET" action="/my/players" class="row g-2 mb-3 align-items-end">
                    <div class="col-auto">
                        <label class="form-label mb-1" for="filter_gender">Gender</label>
                        <select id="filter_gender" name="gender" class="form-select form-select-sm">
                            <option value="">All</option>
                            <option value="male" t-att-selected="'selected' if filter_gender == 'male' else None">Male</option>
                            <option value="female" t-att-selected="'selected' if filter_gender == 'female' else None">Female</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <label class="form-label mb-1" for="filter_state">Status</label>
                        <select id="filter_state" name="state" class="form-select form-select-sm">
                            <option value="">All</option>
                            <option value="active" t-att-selected="'selected' if filter_state == 'active' else None">Active</option>
                            <option value="inactive" t-att-selected="'selected' if filter_state == 'inactive' else None">Inactive</option>
                            <option value="suspended" t-att-selected="'selected' if filter_state == 'suspended' else None">Suspended</option>
                        </select>
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Filter</button>
                        <a href="/my/players" class="btn btn-link btn-sm">Clear</a>
                    </div>
                </form>

                <div t-if="players">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <caption class="visually-hidden">Players registered under the current club representative's clubs.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Name</th>
                                    <th scope="col">Gender</th>
                                    <th scope="col">Birth Date</th>
                                    <th scope="col">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="players" t-as="player">
                                    <tr>
                                        <td class="fw-semibold"><t t-esc="player.name"/></td>
                                        <td><t t-esc="dict(player._fields['gender'].selection).get(player.gender) if player.gender else '—'"/></td>
                                        <td><t t-esc="player.birth_date or '—'"/></td>
                                        <td>
                                            <span t-att-class="'badge text-bg-success' if player.state == 'active' else 'badge text-bg-warning' if player.state == 'suspended' else 'badge text-bg-secondary'">
                                                <t t-esc="dict(player._fields['state'].selection).get(player.state, player.state)"/>
                                            </span>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div t-else="" class="text-center py-5">
                    <i class="fa fa-user fa-3x text-muted mb-3 d-block"/>
                    <p class="fw-semibold mb-1">No players found</p>
                    <p class="text-muted mb-3">
                        <t t-if="filter_gender or filter_state">No players match the selected filters.</t>
                        <t t-else="">Add your first player to begin building your club roster.</t>
                    </p>
                    <a t-if="not filter_gender and not filter_state" href="/my/players/new" class="btn btn-primary">Add Your First Player</a>
                    <a t-else="" href="/my/players" class="btn btn-outline-secondary">Clear Filters</a>
                </div>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Add Player Form                                               -->
    <!-- ============================================================ -->

    <template id="portal_my_player_new" name="Add Player">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3">
                    <div class="col">
                        <h2><i class="fa fa-user-plus me-2"/>Add Player</h2>
                    </div>
                </div>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <form action="/my/players/new" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="mb-3">
                        <label class="form-label" for="player_first_name">First Name <span class="text-danger">*</span></label>
                        <input id="player_first_name" class="form-control" name="first_name" required="required"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player_last_name">Last Name <span class="text-danger">*</span></label>
                        <input id="player_last_name" class="form-control" name="last_name" required="required"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player_birth_date">Birth Date</label>
                        <input id="player_birth_date" class="form-control" name="birth_date" type="date"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player_gender">Gender</label>
                        <select id="player_gender" name="gender" class="form-select">
                            <option value="">— Select —</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player_email">Email</label>
                        <input id="player_email" class="form-control" name="email" type="email"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="player_phone">Phone</label>
                        <input id="player_phone" class="form-control" name="phone"/>
                    </div>

                    <button class="btn btn-primary" type="submit">Add Player</button>
                    <a class="btn btn-secondary" href="/my/players">Cancel</a>
                </form>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- My Season Registrations Page                                  -->
    <!-- ============================================================ -->
    <!-- ============================================================ -->

    <template id="portal_my_season_registrations" name="My Season Registrations">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3">
                    <div class="col">
                        <h2><i class="fa fa-calendar me-2"/>My Season Registrations</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/season-registration/new" class="btn btn-primary">
                            <i class="fa fa-plus me-1"/> New Registration
                        </a>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="table-responsive">
                        <table class="table">
                            <caption class="visually-hidden">Season registrations submitted through the portal.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Reference</th>
                                    <th scope="col">Season</th>
                                    <th scope="col">Team</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="registrations" t-as="reg">
                                    <tr>
                                        <td><t t-esc="reg.name"/></td>
                                        <td><t t-esc="reg.season_id.name"/></td>
                                        <td><t t-esc="reg.team_id.name"/></td>
                                        <td><t t-esc="reg.registration_date" t-options='{"widget": "date"}'/></td>
                                        <td>
                                            <span class="badge"
                                                  t-att-class="'text-bg-warning' if reg.state == 'submitted' else 'text-bg-success' if reg.state == 'confirmed' else 'text-bg-secondary' if reg.state == 'draft' else 'text-bg-danger'">
                                                <t t-esc="dict(reg._fields['state'].selection).get(reg.state)"/>
                                            </span>
                                        </td>
                                        <td>
                                            <form t-if="reg.state in ('draft', 'submitted')"
                                                  t-attf-action="/my/season-registration/#{reg.id}/cancel"
                                                  method="POST" class="d-inline">
                                                <input type="hidden" name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Cancel this registration?')">
                                                    Cancel
                                                </button>
                                            </form>
                                            <t t-if="reg.rejection_reason">
                                                <span class="text-danger small" t-esc="reg.rejection_reason"/>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        </div>
                        <div t-if="not registrations" class="text-center py-4">
                            <p class="text-muted">No season registrations have been submitted yet. Start with the next eligible team when you are ready.</p>
                            <a href="/my/season-registration/new" class="btn btn-primary">
                                Register a Team for a Season
                            </a>
                        </div>
                    </div>
                </div>

                <t t-if="pager">
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- My Tournament Registrations Page                              -->
    <!-- ============================================================ -->

    <template id="portal_my_tournament_registrations" name="My Tournament Registrations">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3">
                    <div class="col">
                        <h2><i class="fa fa-trophy me-2"/>My Tournament Registrations</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/tournaments" class="btn btn-primary">
                            <i class="fa fa-plus me-1"/> Browse Tournaments
                        </a>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="table-responsive">
                        <table class="table">
                            <caption class="visually-hidden">Tournament registrations visible in the portal.</caption>
                            <thead>
                                <tr>
                                    <th scope="col">Reference</th>
                                    <th scope="col">Tournament</th>
                                    <th scope="col">Team</th>
                                    <th scope="col">Date</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="registrations" t-as="reg">
                                    <tr>
                                        <td><t t-esc="reg.name"/></td>
                                        <td>
                                            <a t-attf-href="/tournament/#{reg.tournament_id.id}">
                                                <t t-esc="reg.tournament_id.name"/>
                                            </a>
                                        </td>
                                        <td><t t-esc="reg.team_id.name"/></td>
                                        <td><t t-esc="reg.registration_date" t-options='{"widget": "date"}'/></td>
                                        <td>
                                            <span class="badge"
                                                  t-att-class="'text-bg-warning' if reg.state == 'submitted' else 'text-bg-success' if reg.state == 'confirmed' else 'text-bg-secondary' if reg.state == 'draft' else 'text-bg-danger' if reg.state == 'rejected' else 'text-bg-dark'">
                                                <t t-esc="dict(reg._fields['state'].selection).get(reg.state)"/>
                                            </span>
                                        </td>
                                        <td>
                                            <form t-if="reg.state in ('draft', 'submitted')"
                                                  t-attf-action="/my/tournament-registration/#{reg.id}/cancel"
                                                  method="POST" class="d-inline">
                                                <input type="hidden" name="csrf_token"
                                                       t-att-value="request.csrf_token()"/>
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Cancel this registration?')">
                                                    Cancel
                                                </button>
                                            </form>
                                            <t t-if="reg.rejection_reason">
                                                <span class="text-danger small" t-esc="reg.rejection_reason"/>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        </div>
                        <div t-if="not registrations" class="text-center py-4">
                            <p class="text-muted">No tournament registrations have been sent yet. Browse the published tournament hub to find the next open event.</p>
                            <a href="/tournaments" class="btn btn-primary">
                                Browse Tournaments
                            </a>
                        </div>
                    </div>
                </div>

                <t t-if="pager">
                    <t t-call="portal.pager"/>
                </t>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!-- Season Registration Form                                      -->
    <!-- ============================================================ -->

    <template id="portal_season_registration_form" name="New Season Registration">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-calendar-plus me-2"/>New Season Registration</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/season-registrations" class="btn btn-outline-secondary btn-sm">
                            <i class="fa fa-arrow-left me-1"/>Back
                        </a>
                    </div>
                </div>

                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                </div>

                <div t-if="not seasons" class="alert alert-info" role="status">
                    <i class="fa fa-info-circle me-2"/>
                    No seasons are currently open for registration. Please check back later or contact the federation.
                </div>

                <div t-else="" class="card">
                    <div class="card-body">
                        <form action="/my/season-registration/new" method="POST">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>

                            <div class="mb-3">
                                <label for="team_id" class="form-label">Team <span class="text-danger">*</span></label>
                                <select name="team_id" id="team_id" class="form-select" required="1">
                                    <option value="">— Select a team —</option>
                                    <t t-foreach="teams" t-as="team">
                                        <option t-att-value="team.id"
                                                t-att-selected="'selected' if preselect_team_id == team.id else None">
                                            <t t-esc="team.name"/>
                                        </option>
                                    </t>
                                </select>
                                <div t-if="not teams" class="form-text text-warning">
                                    No teams found. <a href="/my/teams/new">Create a team first.</a>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="season_id" class="form-label">Season <span class="text-danger">*</span></label>
                                <select name="season_id" id="season_id" class="form-select" required="1">
                                    <option value="">— Select a season —</option>
                                    <t t-foreach="seasons" t-as="season">
                                        <option t-att-value="season.id">
                                            <t t-esc="season.name"/>
                                            (<t t-esc="season.date_start" t-options='{"widget": "date"}'/>
                                            – <t t-esc="season.date_end" t-options='{"widget": "date"}'/>)
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="notes" class="form-label">Notes <span class="text-muted">(optional)</span></label>
                                <textarea name="notes" id="notes" class="form-control" rows="3"
                                          placeholder="Any additional information for the federation…"/>
                            </div>

                            <button type="submit" class="btn btn-primary"
                                    t-att-disabled="'disabled' if not teams else None">
                                <i class="fa fa-paper-plane me-1"/>Submit Registration
                            </button>
                            <a href="/my/season-registrations" class="btn btn-outline-secondary ms-2">Cancel</a>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>