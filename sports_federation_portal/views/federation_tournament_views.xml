<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_tournament_form_portal_registrations" model="ir.ui.view">
        <field name="name">federation.tournament.form.portal.registrations</field>
        <field name="model">federation.tournament</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_operations_portal"
                        string="Operations Board"
                        type="object"
                        class="btn-secondary"
                        invisible="id == False"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_registration_requests"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-clipboard">
                    <field name="registration_request_count"
                           widget="statinfo"
                           string="Registrations"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
