<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         portal_my_results  –  Result list
    ================================================================ -->
    <template id="portal_my_results" name="My Results">
        <t t-call="portal.portal_layout">
            <div class="container py-4">

                <div class="row mb-3">
                    <div class="col">
                        <h2><i class="fa fa-check-circle me-2"/>Match Results</h2>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                    <p t-if="error_hint" class="small text-muted mt-1 mb-0">
                        <t t-esc="error_hint"/>
                    </p>
                </div>

                <div t-if="not matches" class="alert alert-info">
                    No match results to review at this time.
                </div>

                <div t-if="matches" class="table-responsive">
                    <table class="table table-sm align-middle">
                        <caption class="visually-hidden">Match results pending review or already actioned by your club.</caption>
                        <thead class="table-light">
                            <tr>
                                <th scope="col">Match</th>
                                <th scope="col">Date</th>
                                <th scope="col" class="text-center">Score</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="matches" t-as="match">
                                <tr>
                                    <td>
                                        <a t-attf-href="/my/results/#{match.id}">
                                            <t t-esc="match.name"/>
                                        </a>
                                        <div class="small text-muted">
                                            <t t-esc="match.tournament_id.name"/>
                                        </div>
                                    </td>
                                    <td>
                                        <t t-if="match.date_scheduled">
                                            <t t-esc="match.date_scheduled" t-options='{"widget": "date"}'/>
                                        </t>
                                        <span t-if="not match.date_scheduled" class="text-muted">—</span>
                                    </td>
                                    <td class="text-center fw-semibold">
                                        <t t-esc="match.home_score"/> – <t t-esc="match.away_score"/>
                                    </td>
                                    <td>
                                        <span t-attf-class="badge #{
                                            'bg-warning text-dark' if match.result_state == 'submitted' else
                                            'bg-info text-dark'    if match.result_state == 'verified'  else
                                            'bg-success'           if match.result_state == 'approved'  else
                                            'bg-danger'            if match.result_state == 'contested' else
                                            'bg-secondary'
                                        }">
                                            <t t-esc="match.result_state.capitalize()"/>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/my/results/#{match.id}"
                                           class="btn btn-sm btn-outline-primary">Review</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <div t-if="pager" class="d-flex justify-content-center mt-3">
                    <t t-call="portal.pager"/>
                </div>

            </div>
        </t>
    </template>

    <!-- ================================================================
         portal_my_result_detail  –  Result detail
    ================================================================ -->
    <template id="portal_my_result_detail" name="Result Detail">
        <t t-call="portal.portal_layout">
            <div class="container py-4">

                <div class="row mb-3">
                    <div class="col">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item">
                                    <a href="/my/results">Results</a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">
                                    <t t-esc="match.name"/>
                                </li>
                            </ol>
                        </nav>
                        <h2><i class="fa fa-check-circle me-2"/>Result: <t t-esc="match.name"/></h2>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                    <p t-if="error_hint" class="small text-muted mt-1 mb-0">
                        <t t-esc="error_hint"/>
                    </p>
                </div>

                <!-- Match summary card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <strong>Match Details</strong>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <dl class="row mb-0">
                                    <dt class="col-sm-4">Tournament</dt>
                                    <dd class="col-sm-8"><t t-esc="match.tournament_id.name"/></dd>

                                    <dt class="col-sm-4">Stage</dt>
                                    <dd class="col-sm-8">
                                        <t t-if="match.stage_id"><t t-esc="match.stage_id.name"/></t>
                                        <span t-if="not match.stage_id" class="text-muted">—</span>
                                    </dd>

                                    <dt class="col-sm-4">Date</dt>
                                    <dd class="col-sm-8">
                                        <t t-if="match.date_scheduled">
                                            <t t-esc="match.date_scheduled" t-options='{"widget": "datetime"}'/>
                                        </t>
                                        <span t-if="not match.date_scheduled" class="text-muted">—</span>
                                    </dd>
                                </dl>
                            </div>
                            <div class="col-md-6">
                                <dl class="row mb-0">
                                    <dt class="col-sm-4">Home</dt>
                                    <dd class="col-sm-8"><t t-esc="match.home_team_id.display_name"/></dd>

                                    <dt class="col-sm-4">Away</dt>
                                    <dd class="col-sm-8"><t t-esc="match.away_team_id.display_name"/></dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Score card -->
                <div class="card mb-4">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <strong>Result</strong>
                        <span t-attf-class="badge #{
                            'bg-warning text-dark' if match.result_state == 'submitted' else
                            'bg-info text-dark'    if match.result_state == 'verified'  else
                            'bg-success'           if match.result_state == 'approved'  else
                            'bg-danger'            if match.result_state == 'contested' else
                            'bg-secondary'
                        }">
                            <t t-esc="match.result_state.capitalize()"/>
                        </span>
                    </div>
                    <div class="card-body text-center">
                        <div class="display-5 fw-bold">
                            <t t-esc="match.home_team_id.display_name"/>
                            <span class="mx-3 text-muted">
                                <t t-esc="match.home_score"/> – <t t-esc="match.away_score"/>
                            </span>
                            <t t-esc="match.away_team_id.display_name"/>
                        </div>
                    </div>
                </div>

                <!-- Contest reason (if present) -->
                <div t-if="match.result_contest_reason" class="card mb-4 border-danger">
                    <div class="card-header bg-danger text-white">
                        <i class="fa fa-exclamation-triangle me-1"/>Contest Reason
                    </div>
                    <div class="card-body">
                        <p class="mb-0"><t t-esc="match.result_contest_reason"/></p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="card mb-4">
                    <div class="card-header"><strong>Actions</strong></div>
                    <div class="card-body">

                        <!-- Pending verification notice (submitted only) -->
                        <t t-if="match.result_state == 'submitted'">
                            <div class="alert alert-info mb-3">
                                <i class="fa fa-clock-o me-1"/>
                                <strong>Awaiting verification.</strong>
                                A federation official must verify this result before it can be approved.
                                You may contest it below if you believe the score is incorrect.
                            </div>
                        </t>

                        <!-- Approve (verified only) -->
                        <t t-if="match.result_state == 'verified'">
                            <p class="text-muted small mb-2">
                                This result has been verified by a federation official.
                                Approve it to include it in official standings.
                            </p>
                            <form t-attf-action="/my/results/#{match.id}/approve"
                                  method="POST"
                                  class="d-inline">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-success me-2">
                                    <i class="fa fa-check me-1"/>Approve Result
                                </button>
                            </form>
                        </t>

                        <!-- Contest (submitted / verified / approved) -->
                        <t t-if="match.result_state in ('submitted', 'verified', 'approved')">
                            <form t-attf-action="/my/results/#{match.id}/contest"
                                  method="POST"
                                  class="mt-3">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-3">
                                    <label for="result_contest_reason" class="form-label fw-semibold">
                                        Contest Reason <span class="text-danger">*</span>
                                    </label>
                                    <textarea id="result_contest_reason"
                                              name="result_contest_reason"
                                              class="form-control"
                                              rows="3"
                                              placeholder="Describe the grounds for contesting this result…"
                                              required="required"/>
                                </div>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fa fa-flag me-1"/>Contest Result
                                </button>
                            </form>
                        </t>

                        <!-- Already contested -->
                        <t t-if="match.result_state == 'contested'">
                            <div class="alert alert-warning mb-0">
                                <i class="fa fa-exclamation-circle me-1"/>
                                This result has been contested and is under federation review.
                                No further action is required from your club at this time.
                            </div>
                        </t>

                        <!-- Approved -->
                        <t t-if="match.result_state == 'approved'">
                            <div class="alert alert-success mb-0 mt-2">
                                <i class="fa fa-trophy me-1"/>
                                This result is approved and included in official standings.
                            </div>
                        </t>

                    </div>
                </div>

                <a href="/my/results" class="btn btn-outline-secondary">
                    <i class="fa fa-arrow-left me-1"/>Back to Results
                </a>

            </div>
        </t>
    </template>

</odoo>
