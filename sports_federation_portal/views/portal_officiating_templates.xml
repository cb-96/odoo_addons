<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="portal_my_referee_assignments" name="My Referee Assignments">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-flag me-2"/>My Officiating Assignments</h2>
                        <p class="text-muted mb-0" t-if="referee">
                            <t t-esc="referee.name"/> can review and respond to assigned matches here.
                        </p>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mb-3">
                    <a t-attf-href="/my/referee-assignments?filterby=upcoming"
                       t-att-class="'btn btn-sm %s' % ('btn-primary' if filterby == 'upcoming' else 'btn-outline-primary')">Upcoming</a>
                    <a t-attf-href="/my/referee-assignments?filterby=pending"
                       t-att-class="'btn btn-sm %s' % ('btn-primary' if filterby == 'pending' else 'btn-outline-primary')">Pending Response</a>
                    <a t-attf-href="/my/referee-assignments?filterby=history"
                       t-att-class="'btn btn-sm %s' % ('btn-primary' if filterby == 'history' else 'btn-outline-primary')">History</a>
                    <a t-attf-href="/my/referee-assignments?filterby=all"
                       t-att-class="'btn btn-sm %s' % ('btn-primary' if filterby == 'all' else 'btn-outline-primary')">All</a>
                </div>

                <div class="table-responsive" t-if="assignments">
                    <table class="table align-middle">
                        <caption class="visually-hidden">Officiating assignments visible to the current referee.</caption>
                        <thead>
                            <tr>
                                <th scope="col">Match</th>
                                <th scope="col">Tournament</th>
                                <th scope="col">Role</th>
                                <th scope="col">Kickoff</th>
                                <th scope="col">Deadline</th>
                                <th scope="col">Status</th>
                                <th scope="col" class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="assignments" t-as="assignment">
                                <tr>
                                    <td>
                                        <strong><t t-esc="assignment.match_id.display_name"/></strong>
                                    </td>
                                    <td><t t-esc="assignment.tournament_id.display_name or ''"/></td>
                                    <td><t t-esc="dict(assignment._fields['role'].selection).get(assignment.role)"/></td>
                                    <td>
                                        <t t-if="assignment.match_kickoff" t-esc="assignment.match_kickoff" t-options='{"widget": "datetime"}'/>
                                    </td>
                                    <td>
                                        <t t-if="assignment.confirmation_deadline" t-esc="assignment.confirmation_deadline" t-options='{"widget": "datetime"}'/>
                                    </td>
                                    <td>
                                        <span class="badge"
                                              t-att-class="'badge text-bg-warning' if assignment.state == 'draft' else ('badge text-bg-success' if assignment.state == 'confirmed' else ('badge text-bg-secondary' if assignment.state == 'done' else 'badge text-bg-danger'))">
                                            <t t-esc="dict(assignment._fields['state'].selection).get(assignment.state)"/>
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <a t-attf-href="/my/referee-assignments/#{assignment.id}" class="btn btn-sm btn-outline-primary">Open</a>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <div t-if="not assignments" class="alert alert-info mb-0" role="status">
                    No officiating assignments match the current filter.
                </div>
            </div>
        </t>
    </template>

    <template id="portal_my_referee_assignment_detail" name="My Referee Assignment Detail">
        <t t-call="portal.portal_layout">
            <div class="container py-4">
                <div class="row mb-3 align-items-center">
                    <div class="col">
                        <h2><i class="fa fa-flag me-2"/>Officiating Assignment</h2>
                    </div>
                    <div class="col-auto">
                        <a href="/my/referee-assignments" class="btn btn-outline-secondary">Back to Assignments</a>
                    </div>
                </div>

                <div t-if="success" class="alert alert-success" role="status">
                    <t t-esc="success"/>
                </div>
                <div t-if="error" class="alert alert-danger" role="alert">
                    <t t-esc="error"/>
                    <p t-if="error_hint" class="small text-muted mt-1 mb-0"><t t-esc="error_hint"/></p>
                </div>

                <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="card">
                            <div class="card-body">
                                <h4 class="card-title mb-3"><t t-esc="assignment.match_id.display_name"/></h4>
                                <table class="table table-sm mb-0">
                                    <tr>
                                        <th style="width: 170px;">Tournament</th>
                                        <td><t t-esc="assignment.tournament_id.display_name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <th>Role</th>
                                        <td><t t-esc="dict(assignment._fields['role'].selection).get(assignment.role)"/></td>
                                    </tr>
                                    <tr t-if="assignment.match_id.home_team_id or assignment.match_id.away_team_id">
                                        <th>Teams</th>
                                        <td>
                                            <t t-esc="assignment.match_id.home_team_id.display_name or 'TBD'"/>
                                            <span class="mx-1">vs</span>
                                            <t t-esc="assignment.match_id.away_team_id.display_name or 'TBD'"/>
                                        </td>
                                    </tr>
                                    <tr t-if="assignment.match_kickoff">
                                        <th>Kickoff</th>
                                        <td><t t-esc="assignment.match_kickoff" t-options='{"widget": "datetime"}'/></td>
                                    </tr>
                                    <tr t-if="assignment.confirmation_deadline">
                                        <th>Confirmation Deadline</th>
                                        <td><t t-esc="assignment.confirmation_deadline" t-options='{"widget": "datetime"}'/></td>
                                    </tr>
                                    <tr>
                                        <th>Status</th>
                                        <td><t t-esc="dict(assignment._fields['state'].selection).get(assignment.state)"/></td>
                                    </tr>
                                    <tr t-if="assignment.notes">
                                        <th>Assignment Notes</th>
                                        <td><t t-esc="assignment.notes"/></td>
                                    </tr>
                                    <tr t-if="assignment.response_note">
                                        <th>Your Response</th>
                                        <td><t t-esc="assignment.response_note"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <div class="card mb-3">
                            <div class="card-body">
                                <h5 class="card-title">Readiness</h5>
                                <p class="mb-2" t-if="assignment.assignment_ready">This assignment is ready for confirmation.</p>
                                <div t-if="assignment.readiness_feedback" class="alert alert-warning mb-0" role="alert">
                                    <pre class="mb-0" style="white-space: pre-wrap;"><t t-esc="assignment.readiness_feedback"/></pre>
                                </div>
                            </div>
                        </div>

                        <div class="card" t-if="assignment.state == 'draft'">
                            <div class="card-body">
                                <h5 class="card-title">Respond</h5>
                                <form t-attf-action="/my/referee-assignments/#{assignment.id}/respond" method="POST">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    <div class="mb-3">
                                        <label class="form-label" for="assignment_response_note">Response Note</label>
                                        <textarea id="assignment_response_note" name="response_note" class="form-control" rows="4" placeholder="Optional note for confirmation, or a short reason if you need to decline."><t t-esc="assignment.response_note or ''"/></textarea>
                                        <div class="form-text">A decline requires a short reason.</div>
                                    </div>
                                    <div class="d-flex gap-2 flex-wrap">
                                        <button type="submit" name="action" value="confirm" class="btn btn-primary">Confirm Assignment</button>
                                        <button type="submit" name="action" value="decline" class="btn btn-outline-danger">Decline Assignment</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>