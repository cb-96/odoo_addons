<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_referee_form" model="ir.ui.view">
        <field name="name">federation.referee.form</field>
        <field name="model">federation.referee</field>
        <field name="arch" type="xml">
            <form string="Referee">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_certifications" type="object"
                                class="oe_stat_button" icon="fa-certificate">
                            <field name="certification_count" widget="statinfo" string="Certifications"/>
                        </button>
                        <button name="action_view_assignments" type="object"
                                class="oe_stat_button" icon="fa-futbol-o">
                            <field name="assignment_count" widget="statinfo" string="Assignments"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Referee Name"/></h1>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                        </group>
                        <group string="Certification">
                            <field name="certification_level"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_referee_list" model="ir.ui.view">
        <field name="name">federation.referee.list</field>
        <field name="model">federation.referee</field>
        <field name="arch" type="xml">
            <list string="Referees">
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="certification_level"/>
                <field name="certification_count"/>
                <field name="assignment_count"/>
            </list>
        </field>
    </record>

    <record id="view_federation_referee_search" model="ir.ui.view">
        <field name="name">federation.referee.search</field>
        <field name="model">federation.referee</field>
        <field name="arch" type="xml">
            <search string="Search Referees">
                <field name="name"/>
                <field name="email"/>
                <separator/>
                <filter name="has_certification" string="Has Certification"
                        domain="[('certification_ids', '!=', False)]"/>
                <filter name="national_plus" string="National or Above"
                        domain="[('certification_level', 'in', ['national', 'international'])]"/>
                <filter name="regional_plus" string="Regional or Above"
                        domain="[('certification_level', 'in', ['regional', 'national', 'international'])]"/>
                <separator/>
                <group>
                    <filter name="level" string="Certification Level" context="{'group_by': 'certification_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_referee_action" model="ir.actions.act_window">
        <field name="name">Referees</field>
        <field name="res_model">federation.referee</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_referee_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first referee.
            </p>
        </field>
    </record>

</odoo>