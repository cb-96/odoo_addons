<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_match_referee_form" model="ir.ui.view">
        <field name="name">federation.match.referee.form</field>
        <field name="model">federation.match.referee</field>
        <field name="arch" type="xml">
            <form string="Match Referee Assignment">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_draft" string="Reset to Assigned" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Assignment">
                            <field name="match_id"/>
                            <field name="tournament_id"/>
                            <field name="role"/>
                            <field name="confirmation_deadline" readonly="1"/>
                            <field name="is_confirmation_overdue" readonly="1"/>
                        </group>
                        <group string="Referee">
                            <field name="referee_id"/>
                            <field name="assignment_ready" readonly="1"/>
                            <field name="readiness_feedback" readonly="1" invisible="not readiness_feedback"/>
                            <field name="assignment_has_warning" readonly="1"/>
                            <field name="assignment_warning_feedback" readonly="1" invisible="not assignment_warning_feedback"/>
                            <field name="assigned_on" readonly="1"/>
                            <field name="confirmed_on" readonly="1" invisible="not confirmed_on"/>
                            <field name="completed_on" readonly="1" invisible="not completed_on"/>
                            <field name="cancelled_on" readonly="1" invisible="not cancelled_on"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_match_referee_list" model="ir.ui.view">
        <field name="name">federation.match.referee.list</field>
        <field name="model">federation.match.referee</field>
        <field name="arch" type="xml">
            <list string="Match Referee Assignments"
                  decoration-danger="is_confirmation_overdue and state == 'draft'">
                <field name="match_id"/>
                <field name="tournament_id"/>
                <field name="referee_id"/>
                <field name="role"/>
                <field name="confirmation_deadline" optional="show"/>
                <field name="is_confirmation_overdue" optional="show"/>
                <field name="assignment_ready" optional="hide"/>
                <field name="assignment_has_warning" optional="show"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_federation_match_referee_search" model="ir.ui.view">
        <field name="name">federation.match.referee.search</field>
        <field name="model">federation.match.referee</field>
        <field name="arch" type="xml">
            <search string="Search Assignments">
                <field name="match_id"/>
                <field name="referee_id"/>
                <field name="tournament_id"/>
                <field name="confirmation_deadline"/>
                <filter name="draft" string="Assigned" domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <group>
                    <filter name="match" string="Match" context="{'group_by': 'match_id'}"/>
                    <filter name="referee" string="Referee" context="{'group_by': 'referee_id'}"/>
                    <filter name="tournament" string="Tournament" context="{'group_by': 'tournament_id'}"/>
                    <filter name="role" string="Role" context="{'group_by': 'role'}"/>
                    <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="federation_match_referee_action" model="ir.actions.act_window">
        <field name="name">Match Assignments</field>
        <field name="res_model">federation.match.referee</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_match_referee_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Assign referees to matches.
            </p>
        </field>
    </record>

</odoo>