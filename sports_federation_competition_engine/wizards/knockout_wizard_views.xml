<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_knockout_wizard_form" model="ir.ui.view">
        <field name="name">federation.knockout.wizard.form</field>
        <field name="model">federation.knockout.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Knockout Bracket">
                <group>
                    <group>
                        <field name="tournament_id"/>
                        <field name="stage_id"/>
                        <field name="participant_source"/>
                        <field name="source_stage_id" invisible="participant_source != 'stage'"/>
                        <field name="participant_ids" invisible="participant_source != 'manual'" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="seeding"/>
                        <field name="bracket_size"/>
                        <field name="bracket_type"/>
                        <field name="start_datetime"/>
                        <field name="interval_hours"/>
                        <field name="venue"/>
                        <field name="overwrite"/>
                    </group>
                </group>
                <separator string="Preview"/>
                <field name="summary" readonly="1"/>
                <div class="alert alert-warning" role="alert" invisible="not overwrite">
                    Overwrite will replace existing matches for the selected stage.
                </div>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_knockout_wizard" model="ir.actions.act_window">
        <field name="name">Generate Knockout Bracket</field>
        <field name="res_model">federation.knockout.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>