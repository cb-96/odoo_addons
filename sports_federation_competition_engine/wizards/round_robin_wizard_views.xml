<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_round_robin_wizard_form" model="ir.ui.view">
        <field name="name">federation.round.robin.wizard.form</field>
        <field name="model">federation.round.robin.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Round-Robin Schedule">
                <group>
                    <group>
                        <field name="tournament_id"/>
                        <field name="stage_id"/>
                        <field name="group_id"/>
                    </group>
                    <group>
                        <field name="round_type"/>
                        <field name="rounds_count"/>
                        <field name="use_all_participants"/>
                        <field name="participant_ids" invisible="use_all_participants"/>
                        <field name="stage_round_count" readonly="1" invisible="not stage_id"/>
                        <field name="schedule_by_round"/>
                    </group>
                </group>
                <group>
                    <group>
                        <field name="start_datetime"/>
                        <field name="interval_hours"/>
                        <field name="round_interval_hours" invisible="not schedule_by_round"/>
                    </group>
                    <group>
                        <field name="venue"/>
                        <field name="overwrite"/>
                    </group>
                </group>
                <div class="alert alert-info" role="status">
                    Matches are assigned to the gamedays you define on the stage. Create your gamedays first, then run this wizard to fill them with matches.
                </div>
                <separator string="Preview"/>
                <field name="summary" readonly="1"/>
                <div class="alert alert-warning" role="status" invisible="not overwrite">
                    Overwrite will replace existing matches for the selected stage or group.
                </div>
                <footer>
                    <button name="action_generate" string="Generate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_round_robin_wizard" model="ir.actions.act_window">
        <field name="name">Generate Round-Robin</field>
        <field name="res_model">federation.round.robin.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>