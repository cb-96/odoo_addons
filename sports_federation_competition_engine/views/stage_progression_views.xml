<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stage_progression_form" model="ir.ui.view">
        <field name="name">federation.stage.progression.form</field>
        <field name="model">federation.stage.progression</field>
        <field name="arch" type="xml">
            <form string="Stage Progression">
                <header>
                    <button name="action_execute" string="Execute Progression" type="object"
                            class="btn-primary" invisible="state != 'pending'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Source">
                            <field name="tournament_id"/>
                            <field name="source_stage_id"/>
                            <field name="source_group_id"/>
                            <field name="cross_group" readonly="1"/>
                        </group>
                        <group string="Target">
                            <field name="target_stage_id"/>
                            <field name="target_group_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Rank Selection">
                            <field name="rank_from"/>
                            <field name="rank_to"/>
                        </group>
                        <group string="Options">
                            <field name="seeding_method"/>
                            <field name="auto_advance"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_stage_progression_tree" model="ir.ui.view">
        <field name="name">federation.stage.progression.tree</field>
        <field name="model">federation.stage.progression</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="source_stage_id"/>
                <field name="source_group_id"/>
                <field name="rank_from"/>
                <field name="rank_to"/>
                <field name="target_stage_id"/>
                <field name="target_group_id"/>
                <field name="seeding_method"/>
                <field name="auto_advance"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_stage_progression" model="ir.actions.act_window">
        <field name="name">Stage Progressions</field>
        <field name="res_model">federation.stage.progression</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
