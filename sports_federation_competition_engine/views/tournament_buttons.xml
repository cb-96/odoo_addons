<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add competition generation buttons to tournament form header -->
    <record id="view_federation_tournament_form_competition_buttons" model="ir.ui.view">
        <field name="name">federation.tournament.form.competition.buttons</field>
        <field name="model">federation.tournament</field>
        <field name="inherit_id" ref="sports_federation_tournament.view_federation_tournament_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_apply_template" string="Apply Template" type="object"
                        class="btn-secondary" invisible="state != 'draft' or not template_id"/>
                <button name="%(action_round_robin_wizard)d" string="Advanced: Round-Robin Wizard" type="action"
                    class="btn-secondary" invisible="state not in ('open', 'in_progress')"
                        context="{'default_tournament_id': id}"/>
                <button name="%(action_knockout_wizard)d" string="Advanced: Knockout Wizard" type="action"
                    class="btn-secondary" invisible="state not in ('open', 'in_progress')"
                        context="{'default_tournament_id': id}"/>
            </xpath>
            <xpath expr="//field[@name='rule_set_id']" position="after">
                <field name="template_id"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Progressions" name="progressions">
                    <field name="progression_ids">
                        <list>
                            <field name="sequence" widget="handle"/>
                            <field name="source_stage_id"/>
                            <field name="source_group_id"/>
                            <field name="rank_from"/>
                            <field name="rank_to"/>
                            <field name="target_stage_id"/>
                            <field name="target_group_id"/>
                            <field name="seeding_method"/>
                            <field name="auto_advance"/>
                            <field name="state"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>