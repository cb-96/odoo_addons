<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_federation_suspension_list" model="ir.ui.view">
        <field name="name">federation.suspension.list</field>
        <field name="model">federation.suspension</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="case_id"/>
                <field name="player_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_federation_suspension_form" model="ir.ui.view">
        <field name="name">federation.suspension.form</field>
        <field name="model">federation.suspension</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state != 'draft'" confirm="Activating this suspension will immediately affect the player's eligibility. Continue?"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ['cancelled', 'expired']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="case_id"/>
                            <field name="player_id"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_federation_suspension_search" model="ir.ui.view">
        <field name="name">federation.suspension.search</field>
        <field name="model">federation.suspension</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="case_id"/>
                <field name="player_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Active" name="active" domain="[('state', '=', 'active')]"/>
                <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="action_federation_suspension" model="ir.actions.act_window">
        <field name="name">Suspensions</field>
        <field name="res_model">federation.suspension</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>