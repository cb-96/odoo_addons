<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Standing Form to add Website fields -->
    <record id="view_federation_standing_form_inherit_public_site" model="ir.ui.view">
        <field name="name">federation.standing.form.inherit.public.site</field>
        <field name="model">federation.standing</field>
        <field name="inherit_id" ref="sports_federation_standings.view_federation_standing_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Website" name="website">
                    <div class="alert alert-info"
                         invisible="state != 'draft'"
                         role="status">
                        <strong>Next step:</strong>
                        No public table appears until approved results have been folded into this standings record.
                    </div>
                    <div class="alert alert-warning"
                         invisible="state == 'draft' or website_published"
                         role="alert">
                        <strong>Hidden:</strong>
                        This standings table is ready for review, but visitors cannot see it until you publish it here.
                    </div>
                    <div class="alert alert-success"
                         invisible="not website_published"
                         role="status">
                        <strong>Public visibility:</strong>
                        This standings table is visible on published tournament pages.
                    </div>
                    <group>
                        <group string="Publication">
                            <field name="website_published"/>
                            <field name="public_title"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>