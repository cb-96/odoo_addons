<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_team_form_inherit_public_site" model="ir.ui.view">
        <field name="name">federation.team.form.inherit.public.site</field>
        <field name="model">federation.team</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_team_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Website">
                    <group>
                        <field name="public_slug"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_federation_club_form_inherit_public_site" model="ir.ui.view">
        <field name="name">federation.club.form.inherit.public.site</field>
        <field name="model">federation.club</field>
        <field name="inherit_id" ref="sports_federation_base.view_federation_club_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Website">
                    <group>
                        <field name="website_published"/>
                        <field name="public_slug"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

</odoo>