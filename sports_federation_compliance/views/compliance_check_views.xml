<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="view_federation_compliance_check_form" model="ir.ui.view">
        <field name="name">federation.compliance.check.form</field>
        <field name="model">federation.compliance.check</field>
        <field name="arch" type="xml">
            <form string="Compliance Check">
                <header>
                    <button name="action_recheck" string="Recheck" type="object" class="btn-primary"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>
                    <group>
                        <group string="General Information">
                            <field name="name"/>
                            <field name="target_model"/>
                            <field name="requirement_id"/>
                        </group>
                        <group string="Check Details">
                            <field name="checked_on"/>
                            <field name="submission_id"/>
                        </group>
                    </group>
                    <group string="Target Entity">
                        <field name="club_id" invisible="target_model != 'federation.club'"/>
                        <field name="player_id" invisible="target_model != 'federation.player'"/>
                        <field name="referee_id" invisible="target_model != 'federation.referee'"/>
                        <field name="venue_id" invisible="target_model != 'federation.venue'"/>
                        <field name="club_representative_id" invisible="target_model != 'federation.club.representative'"/>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_federation_compliance_check_list" model="ir.ui.view">
        <field name="name">federation.compliance.check.list</field>
        <field name="model">federation.compliance.check</field>
        <field name="arch" type="xml">
            <list string="Compliance Checks" decoration-danger="status == 'non_compliant'"
                  decoration-warning="status in ('missing', 'expired')"
                  decoration-success="status == 'compliant'"
                  decoration-info="status == 'pending'">
                <field name="name"/>
                <field name="target_model" optional="show"/>
                <field name="target_display"/>
                <field name="requirement_id"/>
                <field name="status"/>
                <field name="checked_on" optional="show"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_federation_compliance_check_search" model="ir.ui.view">
        <field name="name">federation.compliance.check.search</field>
        <field name="model">federation.compliance.check</field>
        <field name="arch" type="xml">
            <search string="Search Compliance Checks">
                <field name="name"/>
                <field name="requirement_id"/>
                <field name="club_id"/>
                <field name="player_id"/>
                <field name="referee_id"/>
                <field name="venue_id"/>
                <field name="club_representative_id"/>
                <filter name="compliant" string="Compliant" domain="[('status', '=', 'compliant')]"/>
                <filter name="missing" string="Missing" domain="[('status', '=', 'missing')]"/>
                <filter name="pending" string="Pending" domain="[('status', '=', 'pending')]"/>
                <filter name="expired" string="Expired" domain="[('status', '=', 'expired')]"/>
                <filter name="non_compliant" string="Non Compliant" domain="[('status', '=', 'non_compliant')]"/>
                <separator/>
                <filter name="club" string="Club" domain="[('target_model', '=', 'federation.club')]"/>
                <filter name="player" string="Player" domain="[('target_model', '=', 'federation.player')]"/>
                <filter name="referee" string="Referee" domain="[('target_model', '=', 'federation.referee')]"/>
                <filter name="venue" string="Venue" domain="[('target_model', '=', 'federation.venue')]"/>
                <filter name="representative" string="Representative" domain="[('target_model', '=', 'federation.club.representative')]"/>
                <separator/>
                <group>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_target_model" string="Target Model" context="{'group_by': 'target_model'}"/>
                    <filter name="group_requirement" string="Requirement" context="{'group_by': 'requirement_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_federation_compliance_check" model="ir.actions.act_window">
        <field name="name">Compliance Checks</field>
        <field name="res_model">federation.compliance.check</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_federation_compliance_check_search"/>
    </record>

</odoo>