                <group>
                    <filter name="group_type" string="Type" context="{'group_by': 'notification_type'}"/>
                    <filter name="group_failure_category" string="Failure Category" context="{'group_by': 'failure_category'}"/>
                    <filter name="group_model" string="Target Model" context="{'group_by': 'target_model'}"/>
                    <filter name="group_sla" string="SLA Status" context="{'group_by': 'sla_status'}"/>
                </group>
            </search>
        </field>
    </record>

