    <record id="action_federation_report_standing_reconciliation" model="ir.actions.act_window">
        <field name="name">Standings Reconciliation</field>
        <field name="res_model">federation.report.standing.reconciliation</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_federation_report_standing_reconciliation_search"/>
