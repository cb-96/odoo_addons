                <field name="state"/>
                <field name="follow_up_status"/>
                <field name="counterparty_display"/>
                <field name="source_model"/>
                <field name="source_res_id"/>
                <field name="amount"/>
                <field name="external_ref"/>
                <field name="invoice_ref"/>
                <field name="queue_owner_display"/>
                <field name="sla_due_on"/>
                <field name="sla_status"/>
                <field name="age_days"/>
                <field name="needs_follow_up"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_finance_reconciliation_pivot" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.pivot</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
            <pivot string="Finance Reconciliation">
