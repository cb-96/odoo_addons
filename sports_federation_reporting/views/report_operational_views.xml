<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_federation_report_operational_search" model="ir.ui.view">
        <field name="name">federation.report.operational.search</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <search string="Operational KPIs">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="readiness_status"/>
                <field name="readiness_note"/>
                <filter name="blocked" string="Blocked" domain="[('readiness_status', '=', 'blocked')]"/>
                <filter name="attention" string="Attention" domain="[('readiness_status', '=', 'attention')]"/>
                <filter name="open_compliance" string="Open Compliance" domain="[('open_club_compliance_count', '>', 0)]"/>
                <filter name="participant_gaps" string="Participant Gaps" domain="[('participant_count', '>', 0), ('participant_confirmation_rate', '&lt;', 100)]"/>
                <filter name="unfinished_matches" string="Unfinished Matches" domain="[('match_count', '>', 0), ('match_completion_rate', '&lt;', 100)]"/>
                <filter name="pending_finance" string="Pending Finance" domain="[('pending_finance_event_count', '>', 0)]"/>
                <group>
                    <filter name="group_season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'readiness_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_operational_list" model="ir.ui.view">
        <field name="name">federation.report.operational.list</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <list string="Operational KPIs" create="0" edit="0" delete="0">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="tournament_state"/>
                <field name="participant_count"/>
                <field name="confirmed_participant_count"/>
                <field name="participant_confirmation_rate"/>
                <field name="match_count"/>
                <field name="completed_match_count"/>
                <field name="match_completion_rate"/>
                <field name="frozen_standing_count"/>
                <field name="standing_line_coverage"/>
                <field name="pending_finance_event_count"/>
                <field name="pending_finance_amount"/>
                <field name="open_club_compliance_count"/>
                <field name="readiness_status"/>
                <field name="readiness_note"/>
            </list>
        </field>
    </record>

    <record id="view_federation_report_operational_pivot" model="ir.ui.view">
        <field name="name">federation.report.operational.pivot</field>
        <field name="model">federation.report.operational</field>
        <field name="arch" type="xml">
            <pivot string="Operational KPIs">
                <field name="season_id" type="row"/>
                <field name="readiness_status" type="col"/>
                <field name="participant_count" type="measure"/>
                <field name="confirmed_participant_count" type="measure"/>
                <field name="match_count" type="measure"/>
                <field name="completed_match_count" type="measure"/>
                <field name="pending_finance_amount" type="measure"/>
                <field name="open_club_compliance_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_federation_report_operational" model="ir.actions.act_window">
        <field name="name">Operational KPIs</field>
        <field name="res_model">federation.report.operational</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_federation_report_operational_search"/>
    </record>

    <record id="view_federation_report_standing_reconciliation_search" model="ir.ui.view">
        <field name="name">federation.report.standing.reconciliation.search</field>
        <field name="model">federation.report.standing.reconciliation</field>
        <field name="arch" type="xml">
            <search string="Standings Reconciliation">
                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="reconciliation_status"/>
                <filter name="blocked" string="Blocked" domain="[('reconciliation_status', '=', 'blocked')]"/>
                <filter name="attention" string="Attention" domain="[('reconciliation_status', '=', 'attention')]"/>
                <group>
                    <filter name="group_season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'reconciliation_status'}"/>
                </group>
            </search>
        </field>
    </record>

