    <record id="view_federation_report_finance_reconciliation_search" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.search</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
            <search string="Finance Reconciliation">
                <field name="fee_type_id"/>
                <field name="follow_up_status"/>
                <field name="counterparty_display"/>
                <field name="sla_status"/>
                <filter name="needs_follow_up" string="Needs Follow-up" domain="[('needs_follow_up', '=', True)]"/>
                <filter name="awaiting_reference" string="Awaiting Reference" domain="[('follow_up_status', '=', 'awaiting_reference')]"/>
                <filter name="escalated" string="Escalated" domain="[('sla_status', '=', 'escalated')]"/>
                <group>
                    <filter name="group_fee_type" string="Fee Type" context="{'group_by': 'fee_type_id'}"/>
                    <filter name="group_follow_up" string="Follow-up Status" context="{'group_by': 'follow_up_status'}"/>
                    <filter name="group_sla" string="SLA Status" context="{'group_by': 'sla_status'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_federation_report_finance_reconciliation_list" model="ir.ui.view">
        <field name="name">federation.report.finance.reconciliation.list</field>
        <field name="model">federation.report.finance.reconciliation</field>
        <field name="arch" type="xml">
