                <field name="season_id"/>
                <field name="tournament_id"/>
                <field name="exception_type"/>
                <field name="state"/>
                <field name="sla_status"/>
                <filter name="result_queue" string="Result Queue" domain="[('source_model', '=', 'federation.match')]"/>
                <filter name="override_queue" string="Override Queue" domain="[('source_model', '=', 'federation.override.request')]"/>
                <filter name="escalated" string="Escalated" domain="[('sla_status', '=', 'escalated')]"/>
                <group>
                    <filter name="group_type" string="Exception Type" context="{'group_by': 'exception_type'}"/>
                    <filter name="group_season" string="Season" context="{'group_by': 'season_id'}"/>
                    <filter name="group_sla" string="SLA Status" context="{'group_by': 'sla_status'}"/>
                    <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

