        <field name="name">federation.report.notification.exception.list</field>
        <field name="model">federation.report.notification.exception</field>
        <field name="arch" type="xml">
            <list string="Notification Exceptions" create="0" edit="0" delete="0">
                <field name="created_on"/>
                <field name="name"/>
                <field name="notification_type"/>
                <field name="target_model"/>
                <field name="target_res_id"/>
                <field name="recipient_email"/>
                <field name="template_xmlid"/>
                <field name="failure_category"/>
                <field name="queue_owner_display"/>
