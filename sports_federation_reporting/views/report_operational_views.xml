        <field name="name">federation.report.workflow.exception.list</field>
        <field name="model">federation.report.workflow.exception</field>
        <field name="arch" type="xml">
            <list string="Workflow Exceptions" create="0" edit="0" delete="0">
                <field name="raised_on"/>
                <field name="season_id" optional="show"/>
                <field name="tournament_id" optional="show"/>
                <field name="reference_name"/>
                <field name="state"/>
                <field name="exception_type"/>
                <field name="queue_owner_display"/>
                <field name="sla_due_on"/>
                <field name="sla_status"/>
                <field name="age_days"/>
                <field name="responsible_user_id"/>
                <field name="exception_note"/>
            </list>
        </field>
    </record>

    <record id="action_federation_report_workflow_exception" model="ir.actions.act_window">
        <field name="name">Workflow Exceptions</field>
        <field name="res_model">federation.report.workflow.exception</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_federation_report_workflow_exception_search"/>
    </record>

